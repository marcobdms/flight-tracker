{
  "name": "flight-tracker-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:frontend": "wait-on http-get://localhost:8000/health && npm run dev --prefix frontend",
    "dev:backend": "cd backend && .venv\\Scripts\\uvicorn main:app --reload",
    "dev": "concurrently --kill-others-on-fail --prefix \"[{name}]\" --names \"backend,frontend\" --prefix-colors \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^9.0.10"
  }
}
